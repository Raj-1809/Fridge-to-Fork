<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>What's Cooking — Fridge to Fork</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --green: #1D9E75;
    --green-dark: #0F6E56;
    --green-light: #E1F5EE;
    --green-mid: #5DCAA5;
    --amber: #EF9F27;
    --amber-light: #FAEEDA;
    --amber-dark: #854F0B;
    --purple-light: #EEEDFE;
    --purple-dark: #3C3489;
    --blue-light: #E6F1FB;
    --blue-dark: #0C447C;
    --text: #1a1a1a;
    --text-muted: #6b6b6b;
    --text-hint: #9b9b9b;
    --bg: #f7f5f0;
    --surface: #ffffff;
    --border: rgba(0,0,0,0.08);
    --border-strong: rgba(0,0,0,0.15);
    --radius: 14px;
    --radius-sm: 8px;
    --shadow: 0 2px 12px rgba(0,0,0,0.06);
    --shadow-md: 0 4px 24px rgba(0,0,0,0.1);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    font-size: 15px;
  }

  /* NAV */
  nav {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    position: sticky;
    top: 0;
    z-index: 50;
  }
  .nav-brand { display: flex; flex-direction: column; }
  .nav-brand .title { font-family: 'Playfair Display', serif; font-size: 20px; font-weight: 700; color: var(--text); letter-spacing: -0.3px; line-height: 1.1; }
  .nav-brand .sub { font-size: 10px; color: var(--green); font-weight: 500; letter-spacing: 1.5px; text-transform: uppercase; }
  .nav-tabs { display: flex; gap: 4px; }
  .nav-tab { padding: 6px 14px; border-radius: 20px; font-size: 13px; font-weight: 500; cursor: pointer; border: none; background: none; color: var(--text-muted); transition: all 0.15s; }
  .nav-tab.active { background: var(--green); color: white; }
  .nav-tab:hover:not(.active) { background: var(--green-light); color: var(--green-dark); }

  /* LAYOUT */
  .page { display: none; max-width: 680px; margin: 0 auto; padding: 1.5rem 1rem 4rem; animation: fadeIn 0.2s ease; }
  .page.active { display: block; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: translateY(0); } }

  /* HERO */
  .hero { text-align: center; padding: 2rem 0 1.5rem; }
  .hero h1 { font-family: 'Playfair Display', serif; font-size: 34px; font-weight: 700; line-height: 1.2; color: var(--text); }
  .hero h1 span { color: var(--green); }
  .hero p { color: var(--text-muted); font-size: 15px; margin-top: 8px; font-weight: 300; }

  /* CARDS */
  .card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem; margin-bottom: 1rem; box-shadow: var(--shadow); }
  .card-title { font-size: 11px; font-weight: 500; color: var(--text-hint); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.75rem; }

  /* INGREDIENT INPUT */
  .input-row { display: flex; gap: 8px; margin-bottom: 12px; }
  .input-row input { flex: 1; padding: 10px 14px; border: 1px solid var(--border-strong); border-radius: var(--radius-sm); font-size: 14px; font-family: 'DM Sans', sans-serif; outline: none; background: var(--surface); color: var(--text); transition: border-color 0.15s; }
  .input-row input:focus { border-color: var(--green); }
  .btn-green { padding: 10px 18px; background: var(--green); color: white; border: none; border-radius: var(--radius-sm); font-size: 14px; font-weight: 500; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: background 0.15s; white-space: nowrap; }
  .btn-green:hover { background: var(--green-dark); }
  .btn-green:disabled { background: #ccc; cursor: not-allowed; }

  /* PHOTO UPLOAD */
  .photo-area { border: 2px dashed var(--border-strong); border-radius: var(--radius-sm); padding: 1.25rem; text-align: center; cursor: pointer; transition: all 0.15s; position: relative; margin-bottom: 12px; }
  .photo-area:hover { border-color: var(--green); background: var(--green-light); }
  .photo-area input { position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%; }
  .photo-area .icon { font-size: 28px; margin-bottom: 6px; }
  .photo-area p { font-size: 13px; color: var(--text-muted); }
  .photo-area p strong { color: var(--green); }
  .photo-preview { width: 100%; max-height: 160px; object-fit: cover; border-radius: var(--radius-sm); margin-bottom: 10px; display: none; }

  /* QUICK CHIPS */
  .chips { display: flex; flex-wrap: wrap; gap: 6px; }
  .chip { padding: 5px 12px; border: 1px solid var(--border-strong); border-radius: 20px; font-size: 12px; cursor: pointer; background: var(--surface); color: var(--text-muted); transition: all 0.15s; font-family: 'DM Sans', sans-serif; }
  .chip:hover, .chip.selected { background: var(--green-light); color: var(--green-dark); border-color: var(--green-mid); }

  /* INGREDIENT TAGS */
  .tags { display: flex; flex-wrap: wrap; gap: 6px; min-height: 28px; }
  .tag { display: flex; align-items: center; gap: 5px; padding: 5px 10px; background: var(--green-light); border: 1px solid var(--green-mid); border-radius: 20px; font-size: 13px; color: var(--green-dark); }
  .tag button { background: none; border: none; color: var(--green-dark); cursor: pointer; font-size: 14px; line-height: 1; padding: 0; opacity: 0.5; }
  .tag button:hover { opacity: 1; }

  /* FILTERS */
  .filter-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .filter-group label { display: block; font-size: 11px; font-weight: 500; color: var(--text-hint); margin-bottom: 4px; text-transform: uppercase; letter-spacing: 0.5px; }
  .filter-group select { width: 100%; padding: 9px 12px; border: 1px solid var(--border-strong); border-radius: var(--radius-sm); font-size: 13px; font-family: 'DM Sans', sans-serif; background: var(--surface); color: var(--text); cursor: pointer; outline: none; }
  .filter-group select:focus { border-color: var(--green); }

  /* GENERATE BTN */
  .btn-generate { width: 100%; padding: 14px; background: var(--green); color: white; border: none; border-radius: var(--radius-sm); font-size: 15px; font-weight: 500; cursor: pointer; font-family: 'Playfair Display', serif; letter-spacing: 0.3px; transition: background 0.15s; margin-top: 4px; }
  .btn-generate:hover { background: var(--green-dark); }
  .btn-generate:disabled { background: #bbb; cursor: not-allowed; }

  /* LOADING */
  .loading { text-align: center; padding: 2.5rem 1rem; }
  .spinner { width: 36px; height: 36px; border: 2px solid var(--border); border-top-color: var(--green); border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 1rem; }
  @keyframes spin { to { transform: rotate(360deg); } }
  .loading p { color: var(--text-muted); font-size: 14px; }

  /* RECIPE CARDS */
  .recipe-card { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); padding: 1.25rem; margin-bottom: 12px; box-shadow: var(--shadow); }
  .recipe-header { display: flex; justify-content: space-between; align-items: flex-start; gap: 10px; margin-bottom: 10px; }
  .recipe-name { font-family: 'Playfair Display', serif; font-size: 17px; font-weight: 700; color: var(--text); line-height: 1.3; }
  .bookmark-btn { background: none; border: none; cursor: pointer; font-size: 20px; padding: 2px; flex-shrink: 0; transition: transform 0.15s; }
  .bookmark-btn:hover { transform: scale(1.2); }
  .recipe-badges { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 10px; }
  .badge { padding: 3px 9px; border-radius: 20px; font-size: 11px; font-weight: 500; }
  .badge-time { background: var(--blue-light); color: var(--blue-dark); }
  .badge-diff { background: var(--amber-light); color: var(--amber-dark); }
  .badge-cuisine { background: var(--purple-light); color: var(--purple-dark); }
  .badge-macros { background: var(--green-light); color: var(--green-dark); }
  .recipe-desc { font-size: 13px; color: var(--text-muted); line-height: 1.6; margin-bottom: 12px; }
  .recipe-section-title { font-size: 10px; font-weight: 500; color: var(--text-hint); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px; margin-top: 12px; }
  .recipe-ingredients { font-size: 13px; color: var(--text); line-height: 1.9; }
  .recipe-steps { font-size: 13px; color: var(--text); line-height: 1.9; }
  .recipe-steps p { margin-bottom: 4px; }
  .macro-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; margin-top: 12px; }
  .macro-pill { background: var(--bg); border-radius: var(--radius-sm); padding: 8px 4px; text-align: center; }
  .macro-pill .val { font-size: 15px; font-weight: 500; color: var(--text); }
  .macro-pill .lbl { font-size: 10px; color: var(--text-hint); }

  /* SAVED PAGE */
  .empty-state { text-align: center; padding: 3rem 1rem; color: var(--text-muted); }
  .empty-state .big { font-size: 48px; margin-bottom: 1rem; }
  .empty-state p { font-size: 14px; line-height: 1.6; }

  /* SCANNING STATUS */
  .scan-status { padding: 10px 14px; border-radius: var(--radius-sm); font-size: 13px; margin-bottom: 10px; display: none; }
  .scan-status.scanning { background: var(--blue-light); color: var(--blue-dark); display: block; }
  .scan-status.success { background: var(--green-light); color: var(--green-dark); display: block; }
  .scan-status.error { background: #FCEBEB; color: #791F1F; display: block; }

  /* ERROR */
  .error-msg { background: #FCEBEB; border: 1px solid #F09595; border-radius: var(--radius-sm); padding: 12px 16px; color: #791F1F; font-size: 13px; margin-bottom: 1rem; display: none; }

  /* FOOTER */
  footer { text-align: center; padding: 2rem 1rem; color: var(--text-hint); font-size: 12px; }

  @media (max-width: 480px) {
    .filter-grid { grid-template-columns: 1fr; }
    .hero h1 { font-size: 26px; }
    .nav-tab { padding: 6px 10px; font-size: 12px; }
    .macro-row { grid-template-columns: repeat(2, 1fr); }
  }
</style>
</head>
<body>

<nav>
  <div class="nav-brand">
    <span class="title">What's Cooking</span>
    <span class="sub">Fridge to Fork</span>
  </div>
  <div class="nav-tabs">
    <button class="nav-tab active" onclick="showPage('home')">Find recipes</button>
    <button class="nav-tab" onclick="showPage('saved')">Saved <span id="saved-count"></span></button>
  </div>
</nav>

<!-- HOME PAGE -->
<div class="page active" id="page-home">
  <div class="hero">
    <h1>What's in your<br><span>fridge?</span></h1>
    <p>Add your ingredients, we'll handle the rest</p>
  </div>

  <!-- PHOTO SCAN -->
  <div class="card">
    <div class="card-title">Scan your fridge</div>
    <div class="photo-area" id="photoArea">
      <input type="file" accept="image/*" capture="environment" id="photoInput" onchange="handlePhoto(this)">
      <div class="icon">📷</div>
      <p><strong>Take a photo or upload</strong><br>We'll detect your ingredients automatically</p>
    </div>
    <img class="photo-preview" id="photoPreview">
    <div class="scan-status" id="scanStatus"></div>
  </div>

  <!-- MANUAL INPUT -->
  <div class="card">
    <div class="card-title">Or add ingredients manually</div>
    <div class="input-row">
      <input type="text" id="ingredientInput" placeholder="e.g. chicken, garlic, pasta...">
      <button class="btn-green" onclick="addIngredient()">Add</button>
    </div>
    <div class="card-title" style="margin-bottom:8px;">Quick add</div>
    <div class="chips" id="quickChips"></div>
    <div style="margin-top:14px;">
      <div class="card-title" style="margin-bottom:6px;">Your ingredients</div>
      <div class="tags" id="ingredientTags">
        <span style="font-size:13px;color:var(--text-hint);">None added yet</span>
      </div>
    </div>
  </div>

  <!-- FILTERS -->
  <div class="card">
    <div class="card-title">Filters</div>
    <div class="filter-grid">
      <div class="filter-group">
        <label>Cuisine</label>
        <select id="filterCuisine">
          <option value="">Any cuisine</option>
          <option>Italian</option><option>Asian</option><option>Mexican</option>
          <option>Mediterranean</option><option>Indian</option><option>American</option><option>French</option>
        </select>
      </div>
      <div class="filter-group">
        <label>Max time</label>
        <select id="filterTime">
          <option value="">Any time</option>
          <option>15 mins</option><option>30 mins</option><option>45 mins</option><option>1 hour</option>
        </select>
      </div>
      <div class="filter-group">
        <label>Difficulty</label>
        <select id="filterDiff">
          <option value="">Any difficulty</option>
          <option>Easy</option><option>Medium</option><option>Hard</option>
        </select>
      </div>
      <div class="filter-group">
        <label>Goal</label>
        <select id="filterGoal">
          <option value="">No preference</option>
          <option>High protein</option><option>Low carb</option><option>Low calorie</option><option>High fibre</option>
        </select>
      </div>
    </div>
  </div>

  <div class="error-msg" id="errorMsg"></div>
  <button class="btn-generate" id="generateBtn" onclick="generateRecipes()">Find my recipes</button>

  <div id="resultsArea" style="margin-top:1.5rem;"></div>
</div>

<!-- SAVED PAGE -->
<div class="page" id="page-saved">
  <div class="hero" style="padding-bottom:0.5rem;">
    <h1>Saved <span>recipes</span></h1>
    <p>Your favourite finds, always here</p>
  </div>
  <div id="savedArea" style="margin-top:1.5rem;"></div>
</div>

<footer>What's Cooking &mdash; Fridge to Fork &copy; 2026</footer>

<script>
const QUICK = ['Eggs','Chicken','Pasta','Rice','Tomatoes','Garlic','Onion','Cheese','Potatoes','Spinach','Butter','Lemon','Olive oil','Mushrooms','Broccoli','Bacon','Salmon','Peppers','Courgette','Cream'];
let ingredients = [];
let currentRecipes = [];

// QUICK CHIPS
const qc = document.getElementById('quickChips');
QUICK.forEach(q => {
  const c = document.createElement('div');
  c.className = 'chip';
  c.textContent = q;
  c.onclick = () => { if(!ingredients.includes(q)){ ingredients.push(q); renderTags(); } };
  qc.appendChild(c);
});

document.getElementById('ingredientInput').addEventListener('keydown', e => { if(e.key==='Enter') addIngredient(); });

function addIngredient() {
  const inp = document.getElementById('ingredientInput');
  const val = inp.value.trim();
  if(val && !ingredients.map(i=>i.toLowerCase()).includes(val.toLowerCase())) {
    ingredients.push(val); renderTags();
  }
  inp.value = '';
}

function removeIngredient(idx) { ingredients.splice(idx,1); renderTags(); }

function renderTags() {
  const c = document.getElementById('ingredientTags');
  if(!ingredients.length){ c.innerHTML='<span style="font-size:13px;color:var(--text-hint);">None added yet</span>'; return; }
  c.innerHTML = ingredients.map((i,idx) =>
    `<div class="tag">${i}<button onclick="removeIngredient(${idx})">✕</button></div>`
  ).join('');
}

// PHOTO SCAN
async function handlePhoto(input) {
  const file = input.files[0];
  if(!file) return;
  const preview = document.getElementById('photoPreview');
  const status = document.getElementById('scanStatus');
  preview.src = URL.createObjectURL(file);
  preview.style.display = 'block';
  status.className = 'scan-status scanning';
  status.textContent = 'Scanning your fridge... detecting ingredients...';
  try {
    const base64 = await toBase64(file);
    const res = await fetch('/api/scan', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ image: base64, mediaType: file.type })
    });
    const data = await res.json();
    if(data.ingredients && data.ingredients.length) {
      data.ingredients.forEach(i => { if(!ingredients.includes(i)) ingredients.push(i); });
      renderTags();
      status.className = 'scan-status success';
      status.textContent = `Found ${data.ingredients.length} ingredients: ${data.ingredients.join(', ')}`;
    } else {
      status.className = 'scan-status error';
      status.textContent = 'Could not detect ingredients. Try a clearer photo or add manually.';
    }
  } catch(e) {
    status.className = 'scan-status error';
    status.textContent = 'Scan failed. Please add ingredients manually.';
  }
}

function toBase64(file) {
  return new Promise((res,rej) => {
    const r = new FileReader();
    r.onload = () => res(r.result.split(',')[1]);
    r.onerror = () => rej();
    r.readAsDataURL(file);
  });
}

// GENERATE RECIPES
async function generateRecipes() {
  if(!ingredients.length){ showError('Please add at least one ingredient first!'); return; }
  clearError();
  const btn = document.getElementById('generateBtn');
  btn.disabled = true; btn.textContent = 'Finding recipes...';
  const area = document.getElementById('resultsArea');
  area.innerHTML = `<div class="loading"><div class="spinner"></div><p>Our AI chef is cooking up ideas...</p></div>`;

  const cuisine = document.getElementById('filterCuisine').value;
  const time = document.getElementById('filterTime').value;
  const diff = document.getElementById('filterDiff').value;
  const goal = document.getElementById('filterGoal').value;

  try {
    const res = await fetch('/api/recipes', {
      method: 'POST',
      headers: {'Content-Type':'application/json'},
      body: JSON.stringify({ ingredients, cuisine, time, diff, goal })
    });
    const data = await res.json();
    if(data.recipes) { currentRecipes = data.recipes; renderRecipes(area); }
    else { area.innerHTML=''; showError('No recipes found. Try different ingredients.'); }
  } catch(e) {
    area.innerHTML=''; showError('Something went wrong. Please try again.');
  }
  btn.disabled = false; btn.textContent = 'Find my recipes';
}

function renderRecipes(area) {
  if(!currentRecipes.length){ area.innerHTML='<div class="empty-state"><p>No recipes found. Try different ingredients or filters.</p></div>'; return; }
  area.innerHTML = currentRecipes.map((r,i) => recipeHTML(r, i, false)).join('');
}

function recipeHTML(r, i, isSaved) {
  const saved = getSaved();
  const isBookmarked = saved.some(s => s.name === r.name);
  const bookmarkIcon = isBookmarked ? '🔖' : '🔗';
  return `<div class="recipe-card">
    <div class="recipe-header">
      <div class="recipe-name">${r.name}</div>
      <button class="bookmark-btn" onclick="toggleSave(${i}, ${isSaved})" title="${isBookmarked?'Remove':'Save'} recipe">${bookmarkIcon}</button>
    </div>
    <div class="recipe-badges">
      <span class="badge badge-time">${r.time}</span>
      <span class="badge badge-diff">${r.difficulty}</span>
      <span class="badge badge-cuisine">${r.cuisine}</span>
      <span class="badge badge-macros">${r.macros.calories} kcal</span>
    </div>
    <div class="recipe-desc">${r.description}</div>
    <div class="macro-row">
      <div class="macro-pill"><div class="val">${r.macros.calories}</div><div class="lbl">kcal</div></div>
      <div class="macro-pill"><div class="val">${r.macros.protein}g</div><div class="lbl">protein</div></div>
      <div class="macro-pill"><div class="val">${r.macros.carbs}g</div><div class="lbl">carbs</div></div>
      <div class="macro-pill"><div class="val">${r.macros.fat}g</div><div class="lbl">fat</div></div>
    </div>
    <div class="recipe-section-title">Ingredients</div>
    <div class="recipe-ingredients">${r.ingredients.join(' · ')}</div>
    <div class="recipe-section-title">Instructions</div>
    <div class="recipe-steps">${r.steps.map((s,n)=>`<p>${n+1}. ${s}</p>`).join('')}</div>
  </div>`;
}

// BOOKMARKS
function getSaved() { try { return JSON.parse(localStorage.getItem('wc_saved') || '[]'); } catch{ return []; } }
function setSaved(arr) { localStorage.setItem('wc_saved', JSON.stringify(arr)); updateSavedCount(); }

function toggleSave(i, isSaved) {
  let saved = getSaved();
  const recipe = isSaved ? saved[i] : currentRecipes[i];
  if(!recipe) return;
  const exists = saved.findIndex(s => s.name === recipe.name);
  if(exists >= 0) { saved.splice(exists,1); } else { saved.push(recipe); }
  setSaved(saved);
  if(isSaved) renderSavedPage();
  else renderRecipes(document.getElementById('resultsArea'));
}

function updateSavedCount() {
  const saved = getSaved();
  const el = document.getElementById('saved-count');
  el.textContent = saved.length ? `(${saved.length})` : '';
}

function renderSavedPage() {
  const saved = getSaved();
  const area = document.getElementById('savedArea');
  if(!saved.length){
    area.innerHTML=`<div class="empty-state"><div class="big">🔖</div><p>No saved recipes yet.<br>Find a recipe you love and tap the bookmark icon!</p></div>`;
    return;
  }
  const tempCurrentRecipes = currentRecipes;
  currentRecipes = saved;
  area.innerHTML = saved.map((r,i) => recipeHTML(r, i, true)).join('');
  currentRecipes = tempCurrentRecipes;
}

// PAGES
function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-tab').forEach(t => t.classList.remove('active'));
  document.getElementById('page-'+name).classList.add('active');
  event.target.classList.add('active');
  if(name==='saved') renderSavedPage();
}

function showError(msg) { const el=document.getElementById('errorMsg'); el.style.display='block'; el.textContent=msg; }
function clearError() { document.getElementById('errorMsg').style.display='none'; }

updateSavedCount();
</script>
</body>
</html>
